# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secret-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Open Wearables (https://github.com/the-momentum/open-wearables)
# WEARABLES_URL = Railway URL of the open-wearables backend (port 8000)
WEARABLES_URL=https://your-open-wearables-backend.railway.app
# WEARABLES_API_KEY = API key from the open-wearables developer portal
WEARABLES_API_KEY=your-api-key-here
