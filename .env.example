# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secret-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# App URL (set to your Netlify URL in production)
URL=https://your-app.netlify.app

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM=noreply@yourdomain.com

# Strava OAuth (https://developers.strava.com)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# Random string used to verify the Strava webhook subscription
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# Secret to protect the one-time webhook setup endpoint
STRAVA_WEBHOOK_SETUP_SECRET=your-random-setup-secret

