# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secret-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Open Wearables (https://github.com/hvanarkel-ship-it/open-wearables)
WEARABLES_URL=https://your-open-wearables-service.railway.app
WEARABLES_CLIENT_ID=your-client-id
WEARABLES_CLIENT_SECRET=your-client-secret
